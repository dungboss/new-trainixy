          "settings": {
            "title": "Still Wearing a CPAP Mask? A Former Pacemaker Engineer Built the Device That Makes It Obsolete (No Mask, No Mouthpiece)",
            "title_highlight_1": "none",
            "title_highlight_2": "none",
            "heading_size": "h1",
            "alignment": "center",
            "mobile_alignment": "mobile-center",
            "margin_top": 21,
            "margin_bottom": 12
          }
        },
        "cpap-subtitle-hero": {
          "type": "text",
          "settings": {
            "text": "<p><em>After 15 years designing life-saving pacemakers, one engineer asked: why are we still strapping masks to people's faces? His answer is disrupting the $6.2 billion sleep apnea industry.</em></p>",
            "alignment": "center",
            "mobile_alignment": "mobile-center",
            "text_size": 18,
            "margin_top": 9,
            "margin_bottom": 21
          }
        }
      },
      "block_order": [
