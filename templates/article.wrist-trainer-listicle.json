        "rank_4": {
          "type": "ranking_card",
          "settings": {
            "rank_text": "#4",
            "label": "Mostly Marketing · Not Recommended",
            "title": "Neoprene Arm Trimmer Sleeves",
            "tagline": "You're sweating, not slimming — and there's a real difference",
            "icon": "science",
