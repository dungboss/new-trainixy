          "settings": {
            "post_author": "Lina Torres",
            "post_author_verified": false,
            "post_time": "1 Day ago",
            "post_text": "<p>i run a small preschool movement group and this has been great for balance stations. the kids line up to try it, and even the ones who are usually hesitant join in after watching a friend do it first. it's an easy way to work on focus, coordination, and taking turns without needing a big setup.</p>",
            "post_image": "",
            "post_reactions": "like, love, care",
            "post_reactions_text": "2.4k",
