        "column_BgX46J": {
          "type": "column",
          "settings": {
            "post_author": "Daniel K.",
            "post_author_verified": false,
            "post_time": "5h ago",
            "post_text": "<p>my son loves obstacle courses, so this fit right in. we use it with stepping stones and cones in the living room when the weather is bad. it's one of the few toys that actually gets him moving without a screen. compact, easy to store, and sturdy enough for everyday play.</p>",
            "post_image": "",
