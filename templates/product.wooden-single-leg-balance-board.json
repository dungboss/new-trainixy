      "blocks": {
        "column_Y9BLnV": {
          "type": "column",
          "settings": {
            "post_author": "Megan R.",
            "post_author_verified": false,
            "post_time": "22h ago",
            "post_text": "<p>bought this for my 5-year-old because she needs movement breaks after school and it has been such a good addition to our playroom. she turns it into a game and tries to beat her own balance time every day. i've noticed better coordination and way more confidence when she plays. simple idea, but she uses it constantly.</p>",
            "post_image": "",
            "post_reactions": "like, love, care",
            "post_reactions_text": "1.2k",
            "post_comments_text": "384 Comments",
            "comment_1_author": "Comment author",
