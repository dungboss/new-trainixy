{%- liquid
  assign page_narrow_class = ''
  if section.settings.page_width == 'narrow'
    assign page_narrow_class = ' page-width--narrow'
  endif

  assign method_cards = section.blocks | where: 'type', 'method_card'
  assign ranking_cards = section.blocks | where: 'type', 'ranking_card'
  assign faq_items = section.blocks | where: 'type', 'faq_item'
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .wrist-listicle {
    --wl-bg: {{ section.settings.background_color }};
    --wl-surface: {{ section.settings.surface_color }};
    --wl-surface-alt: {{ section.settings.surface_alt_color }};
    --wl-ink: {{ section.settings.ink_color }};
    --wl-muted: {{ section.settings.muted_color }};
    --wl-accent: {{ section.settings.accent_color }};
    --wl-accent-soft: {{ section.settings.accent_soft_color }};
    --wl-border: {{ section.settings.border_color }};
    --wl-highlight: {{ section.settings.highlight_color }};
    --wl-success: {{ section.settings.success_color }};
    --wl-danger: {{ section.settings.danger_color }};
    --wl-text-scale: {{ section.settings.font_scale | divided_by: 100.0 }};
    background: var(--wl-bg);
    color: var(--wl-ink);
  }

  .wrist-listicle * {
    box-sizing: border-box;
  }

  .wrist-listicle .rte p,
  .wrist-listicle .rte ul,
  .wrist-listicle .rte ol {
    margin: 0 0 1rem;
  }

  .wrist-listicle .rte p:last-child,
  .wrist-listicle .rte ul:last-child,
  .wrist-listicle .rte ol:last-child {
    margin-bottom: 0;
  }

  .wrist-listicle .rte {
    font-size: calc(1rem * var(--wl-text-scale));
    line-height: 1.85;
  }

  .wrist-listicle__stack {
    display: grid;
    gap: 48px;
  }

  .wrist-listicle__hero {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    padding: 48px 28px 42px;
    text-align: center;
    background: linear-gradient(135deg, #1a1410 0%, #2d2318 52%, #1a1410 100%);
    color: #fff;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }

  .wrist-listicle__hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 25% 30%, rgba(200, 145, 42, 0.16), transparent 42%),
      radial-gradient(circle at 80% 40%, rgba(122, 158, 138, 0.12), transparent 45%);
    pointer-events: none;
  }

  .wrist-listicle__hero-inner,
  .wrist-listicle__section-inner {
    position: relative;
    z-index: 1;
  }

  .wrist-listicle__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(200, 145, 42, 0.18);
    color: var(--wl-accent-soft);
    font-size: calc(0.8rem * var(--wl-text-scale));
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .wrist-listicle__title {
    margin: 18px auto 14px;
    max-width: 900px;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2.35rem, 5vw, 4.4rem);
    line-height: 1.12;
    letter-spacing: calc(var(--font-heading-letter-spacing) * 0.7);
    color: #fff;
  }

  .wrist-listicle__title-main {
    display: inline-block;
    font-size: clamp(2.8rem, 6vw, 5.05rem);
    line-height: 1.06;
  }

  .wrist-listicle__title-emphasis {
    display: inline-block;
    margin-top: 0.14em;
    font-size: clamp(0.98rem, 3vw, 2.05rem);
    line-height: 1.1;
    letter-spacing: calc(var(--font-heading-letter-spacing) * 0.35);
    white-space: nowrap;
    color: var(--wl-accent-soft);
    font-style: italic;
  }

  .wrist-listicle__byline {
    color: rgba(255, 255, 255, 0.72);
    font-size: calc(1.02rem * var(--wl-text-scale));
    line-height: 1.6;
    max-width: 860px;
    margin: 0 auto;
  }

  .wrist-listicle__pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 24px;
  }

  .wrist-listicle__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 15px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    font-size: calc(0.9rem * var(--wl-text-scale));
    font-weight: 600;
  }

  .wrist-listicle__pill-icon {
    color: var(--wl-accent-soft);
    line-height: 1;
  }

  .wrist-listicle__section {
    margin-top: 48px;
  }

  .wrist-listicle__section-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 22px;
  }

  .wrist-listicle__section-label::before,
  .wrist-listicle__section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--wl-border);
  }

  .wrist-listicle__section-label span {
    white-space: nowrap;
    color: var(--wl-accent);
    font-size: calc(0.8rem * var(--wl-text-scale));
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .wrist-listicle__section-title {
    margin: 0 0 16px;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: clamp(1.95rem, 3vw, 2.8rem);
    line-height: 1.2;
    color: var(--wl-ink);
  }

  .wrist-listicle__section-intro {
    color: var(--wl-muted);
    font-size: calc(1.08rem * var(--wl-text-scale));
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .wrist-listicle__intro {
    max-width: 820px;
    margin: 0 auto;
    padding-top: 4px;
  }

  .wrist-listicle__intro-copy {
    color: var(--wl-muted);
    font-size: calc(1.12rem * var(--wl-text-scale));
    line-height: 1.82;
  }

  .wrist-listicle__pullquote {
    margin: 24px 0;
    padding: 20px 24px;
    border-radius: 18px;
    border-left: 4px solid var(--wl-accent);
    background: var(--wl-surface-alt);
  }

  .wrist-listicle__pullquote p {
    margin: 0;
    color: var(--wl-ink);
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: calc(1.24rem * var(--wl-text-scale));
    line-height: 1.7;
  }

  .method-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .method-card {
    padding: 20px;
    border: 1px solid var(--wl-border);
    border-radius: 18px;
    background: var(--wl-surface);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.04);
    animation: fadeUp 0.5s ease both;
  }

  .method-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(200, 145, 42, 0.12);
    color: var(--wl-accent);
    margin-bottom: 12px;
  }

  .method-card__icon .material-icon {
    font-size: 22px;
  }

  .method-card__title {
    margin: 0 0 8px;
    font-size: calc(1.08rem * var(--wl-text-scale));
    line-height: 1.35;
    color: var(--wl-ink);
  }

  .method-card__text {
    margin: 0;
    color: var(--wl-muted);
    font-size: calc(0.98rem * var(--wl-text-scale));
    line-height: 1.7;
  }

  .ranking-section {
    padding-top: 8px;
  }

  .ranking-intro {
    margin-bottom: 26px;
  }

  .ranking-intro .rte p,
  .ranking-intro p {
    color: var(--wl-muted);
  }

  .ranking-intro strong {
    color: var(--wl-ink);
  }

  .product-card {
    margin-bottom: 32px;
    overflow: hidden;
    border: 1px solid var(--wl-border);
    border-radius: 10px;
    background: #fff;
    box-shadow: none;
    animation: fadeUp 0.5s ease both;
  }

  .product-card.is-top-pick {
    box-shadow: 0 4px 24px rgba(44, 117, 55, 0.1);
  }

  .product-card__header {
    padding: 28px 28px 0;
    border: 0;
    background: transparent;
  }

  .product-card__rankline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }

  .product-card__rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    height: auto;
    border-radius: 0;
    font-weight: 700;
    font-size: calc(0.92rem * var(--wl-text-scale));
    flex-shrink: 0;
    color: #2c7537;
    background: transparent;
  }

  .product-card__rank.tone-silver {
    color: #2c7537;
    background: transparent;
  }

  .product-card__rank.tone-bronze {
    color: #2c7537;
    background: transparent;
  }

  .product-card__rank.tone-neutral {
    color: #2c7537;
    background: transparent;
    border: 0;
  }

  .product-card__rank.tone-dark {
    color: #2c7537;
    background: transparent;
  }

  .product-card__label {
    font-size: calc(0.92rem * var(--wl-text-scale));
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: none;
    color: #2c7537;
  }

  .product-card__label.is-pick {
    color: #2c7537;
  }

  .product-card__body {
    padding: 12px 28px 0;
  }

  .product-card__title {
    margin: 0 0 8px;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2rem, 3vw, 2.55rem);
    line-height: 1.2;
    color: var(--wl-ink);
  }

  .product-card.is-top-pick .product-card__title {
    font-size: clamp(2.25rem, 3.3vw, 2.85rem);
  }

  .product-card__tagline {
    margin: 0 0 20px;
    color: var(--wl-muted);
    font-size: calc(1.06rem * var(--wl-text-scale));
    font-style: normal;
    line-height: 1.6;
  }

  .product-visual {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    margin-bottom: 20px;
    border-radius: 8px;
    background: linear-gradient(135deg, #f5f0e8 0%, #ede8e0 100%);
  }

  .product-visual__inner {
    width: 100%;
    text-align: center;
    padding: 32px 24px;
  }

  .product-visual__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
    color: var(--wl-ink);
    font-size: 54px;
    line-height: 1;
  }

  .product-visual__icon .material-icon {
    font-size: 54px;
  }

  .product-visual__title {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: calc(1.18rem * var(--wl-text-scale));
    color: var(--wl-ink);
  }

  .product-visual__note {
    margin-top: 6px;
    color: #777;
    font-size: calc(0.9rem * var(--wl-text-scale));
    line-height: 1.5;
  }

  .grade-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    color: #fff;
    font-weight: 700;
    font-size: calc(1.05rem * var(--wl-text-scale));
  }

  .tone-gold {
    background: #2e7d32;
  }

  .tone-silver {
    background: #5d8a3c;
  }

  .tone-bronze {
    background: #9e6a1a;
  }

  .tone-neutral {
    background: #c0392b;
  }

  .tone-dark {
    background: #4b4038;
  }

  .specs-table {
    width: 100%;
    margin-bottom: 24px;
    border-collapse: collapse;
    font-size: calc(0.98rem * var(--wl-text-scale));
  }

  .specs-table td {
    padding: 10px 14px;
    border-bottom: 1px solid #f0ebe5;
    vertical-align: top;
  }

  .specs-table td:first-child {
    width: 38%;
    background: var(--wl-surface);
    color: var(--wl-muted);
    font-weight: 700;
  }

  .score-grid {
    margin: 20px 0 28px;
    padding: 18px;
    border: 1px solid var(--wl-border);
    border-radius: 16px;
    background: #fff;
  }

  .score-row {
    display: grid;
    grid-template-columns: minmax(120px, 160px) 1fr 42px;
    gap: 12px;
    align-items: center;
    margin-bottom: 10px;
  }

  .score-label {
    color: var(--wl-muted);
    font-size: calc(0.96rem * var(--wl-text-scale));
    font-weight: 600;
  }

  .score-bar-bg {
    height: 8px;
    background: #ede8e0;
    border-radius: 4px;
    overflow: hidden;
  }

  .score-bar {
    display: block;
    height: 100%;
    border-radius: 4px;
    background: linear-gradient(90deg, #7a9e8a, #b5d4c3);
    transition: width 1s ease;
  }

  .score-bar.low {
    background: linear-gradient(90deg, #c0392b, #e07070);
  }

  .score-bar.mid {
    background: linear-gradient(90deg, var(--wl-accent), var(--wl-accent-soft));
  }

  .score-val {
    text-align: right;
    color: var(--wl-ink);
    font-size: calc(0.96rem * var(--wl-text-scale));
    font-weight: 700;
  }

  .pros-cons {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin: 24px 0;
  }

  .pros,
  .cons,
  .testimonial-strip,
  .verdict-box,
  .guide-card,
  .author-bio {
    border: 1px solid var(--wl-border);
    border-radius: 16px;
    background: #fff;
  }

  .pros,
  .cons {
    padding: 18px 20px;
  }

  .pros {
    background: #f0f7f3;
    border-color: rgba(122, 158, 138, 0.45);
  }

  .cons {
    background: #fdf4f3;
    border-color: rgba(212, 117, 106, 0.35);
  }

  .pros h4,
  .cons h4 {
    margin: 0 0 12px;
    font-size: calc(0.9rem * var(--wl-text-scale));
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pros h4 {
    color: var(--wl-success);
  }

  .cons h4 {
    color: var(--wl-danger);
  }

  .pros ul,
  .cons ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pros li,
  .cons li {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    margin: 0;
    padding: 5px 0;
    color: var(--wl-muted);
    line-height: 1.6;
    font-size: calc(0.98rem * var(--wl-text-scale));
  }

  .pros li::before {
    content: '+';
    color: var(--wl-success);
    font-weight: 700;
    flex-shrink: 0;
  }

  .cons li::before {
    content: 'x';
    color: var(--wl-danger);
    font-weight: 700;
    flex-shrink: 0;
  }

  .testimonial-strip {
    padding: 18px 20px;
    margin: 14px 0;
    background: var(--wl-surface-alt);
  }

  .testimonial-stars {
    margin-bottom: 8px;
    color: #d09b29;
    font-size: calc(0.88rem * var(--wl-text-scale));
    letter-spacing: 0.08em;
  }

  .testimonial-strip p {
    margin: 0 0 8px;
    color: var(--wl-muted);
    font-style: italic;
    font-size: calc(0.98rem * var(--wl-text-scale));
    line-height: 1.7;
  }

  .testimonial-strip .attr {
    color: var(--wl-accent);
    font-size: calc(0.88rem * var(--wl-text-scale));
    font-weight: 700;
  }

  .product-card__subheading {
    margin: 26px 0 16px;
    font-size: calc(1.12rem * var(--wl-text-scale));
    line-height: 1.3;
    color: var(--wl-ink);
  }

  .product-card .verdict-box {
    margin: 20px 0 0;
    padding: 20px 24px;
    border-radius: 10px;
    background: #fff9f2;
    border-color: var(--wl-border);
  }

  .product-card .verdict-box h4 {
    margin: 0 0 10px;
    color: var(--wl-muted);
    font-size: calc(0.88rem * var(--wl-text-scale));
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .product-card .verdict-box p {
    margin: 0;
    color: var(--wl-muted);
    font-size: calc(0.98rem * var(--wl-text-scale));
    line-height: 1.65;
  }

  .product-card .verdict-box p + p {
    margin-top: 12px;
  }

  .product-card .verdict-box strong {
    color: var(--wl-ink);
  }

  .highlight-box {
    margin: 20px 0;
    padding: 16px 18px;
    border-radius: 14px;
    border: 1px solid rgba(200, 145, 42, 0.3);
    background: var(--wl-highlight);
    color: #5a4500;
    font-size: calc(1rem * var(--wl-text-scale));
    line-height: 1.75;
  }

  .highlight-box strong {
    color: #3a2c00;
  }

  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin: 22px 0 8px;
  }

  .how-step {
    text-align: center;
    padding: 18px 16px;
    border: 1px solid var(--wl-border);
    border-radius: 16px;
    background: #fff;
  }

  .step-num {
    width: 36px;
    height: 36px;
    margin: 0 auto 12px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: var(--wl-accent);
    font-size: calc(0.92rem * var(--wl-text-scale));
    font-weight: 700;
  }

  .how-step h5 {
    margin: 0 0 8px;
    color: var(--wl-ink);
    font-size: calc(0.96rem * var(--wl-text-scale));
    font-weight: 700;
  }

  .how-step p {
    margin: 0;
    color: var(--wl-muted);
    font-size: calc(0.9rem * var(--wl-text-scale));
    line-height: 1.65;
  }

  .compare-table-wrap {
    overflow-x: auto;
    margin: 28px 0 10px;
    border-radius: 18px;
    border: 1px solid var(--wl-border);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .compare-table {
    width: 100%;
    min-width: 720px;
    border-collapse: collapse;
    font-size: calc(0.92rem * var(--wl-text-scale));
  }

  .compare-table th {
    padding: 13px 16px;
    background: #2d2926;
    color: #ddd;
    white-space: nowrap;
    font-size: calc(0.86rem * var(--wl-text-scale));
    font-weight: 700;
    letter-spacing: 0.04em;
    text-align: left;
  }

  .compare-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--wl-border);
    color: var(--wl-muted);
  }

  .compare-table tr:nth-child(even) td {
    background: var(--wl-surface);
  }

  .compare-table tr.top-pick td {
    background: #fff9ee;
  }

  .product-name-cell {
    color: var(--wl-ink);
    font-weight: 700;
  }

  .score-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 42px;
    padding: 3px 9px;
    border-radius: 999px;
    color: #fff;
    background: var(--wl-success);
    font-size: calc(0.86rem * var(--wl-text-scale));
    font-weight: 700;
  }

  .score-chip.tone-silver {
    background: #5d8a3c;
  }

  .score-chip.tone-bronze {
    background: #9e6a1a;
  }

  .score-chip.tone-neutral {
    background: #c0392b;
  }

  .score-chip.tone-dark {
    background: #4b4038;
  }

  .why-section {
    padding: 36px 32px;
    border-radius: 22px;
    background: linear-gradient(135deg, #1a1410, #2a1e14);
    color: #fff;
    overflow: hidden;
    position: relative;
  }

  .why-section::before {
    content: '';
    position: absolute;
    top: -36px;
    right: -36px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200, 145, 42, 0.15), transparent 66%);
    pointer-events: none;
  }

  .why-section .wrist-listicle__section-title {
    color: #fff;
  }

  .why-section .rte,
  .why-section p {
    color: rgba(255, 255, 255, 0.78);
  }

  .why-section strong {
    color: var(--wl-accent-soft);
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .guide-card {
    padding: 20px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
  }

  .guide-card--good {
    background: #f0f7f3;
    border-color: rgba(122, 158, 138, 0.45);
  }

  .guide-card--bad {
    background: #fff7f5;
    border-color: rgba(212, 117, 106, 0.3);
  }

  .guide-card__title {
    margin: 0 0 10px;
    font-size: calc(0.98rem * var(--wl-text-scale));
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .guide-card--good .guide-card__title {
    color: var(--wl-success);
  }

  .guide-card--bad .guide-card__title {
    color: var(--wl-danger);
  }

  .faq-section {
    margin-top: 48px;
  }

  .faq-item {
    border-bottom: 1px solid var(--wl-border);
    padding: 20px 0;
  }

  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--wl-ink);
    font-size: calc(1.08rem * var(--wl-text-scale));
    font-weight: 700;
    text-align: left;
  }

  .faq-q::after {
    content: '+';
    flex-shrink: 0;
    color: var(--wl-accent);
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .faq-item.is-open .faq-q::after {
    transform: rotate(45deg);
  }

  .faq-a {
    display: none;
    padding-top: 14px;
    color: var(--wl-muted);
    font-size: calc(1rem * var(--wl-text-scale));
    line-height: 1.8;
  }

  .faq-item.is-open .faq-a {
    display: block;
  }

  .final-verdict-copy p {
    margin: 0 0 16px;
    color: var(--wl-muted);
    font-size: calc(1rem * var(--wl-text-scale));
    line-height: 1.75;
  }

  .final-verdict-copy p:last-child {
    margin-bottom: 20px;
  }

  .final-cta {
    margin: 48px 0;
    padding: 40px 36px;
    border-radius: 16px;
    text-align: center;
    background: var(--wl-accent);
    color: #fff;
  }

  .final-cta h2 {
    color: #fff;
    font-size: calc(1.8rem * var(--wl-text-scale));
    margin: 0 0 12px;
  }

  .final-cta p {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 24px;
    font-size: calc(0.95rem * var(--wl-text-scale));
    line-height: 1.7;
  }

  .final-cta .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 40px;
    border-radius: 6px;
    background: #fff;
    color: var(--wl-accent);
    font-size: calc(1rem * var(--wl-text-scale));
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
  }

  .final-cta .cta-btn:hover {
    background: #2d2926;
    color: var(--wl-accent-soft);
  }

  .final-cta__meta {
    margin-top: 14px;
    color: rgba(255, 255, 255, 0.7);
    font-size: calc(0.82rem * var(--wl-text-scale));
    line-height: 1.6;
  }

  .ranking-section .final-cta {
    margin: 28px 0 0;
    padding: 24px 28px;
    border-radius: 0 0 10px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ranking-section .final-cta .cta-btn {
    display: inline-flex;
    width: auto;
    min-width: 280px;
    margin: 0 auto;
    padding: 14px 24px;
    border-radius: 6px;
    background: var(--wl-accent);
    color: #fff;
  }

  .ranking-section .final-cta__meta {
    max-width: 36rem;
    text-align: center;
    margin-top: 10px;
    font-size: calc(0.82rem * var(--wl-text-scale));
  }

  .ranking-section .final-cta.is-secondary .cta-btn {
    background: #888;
    color: #fff;
  }

  .ranking-section .final-cta.is-secondary .cta-btn:hover {
    background: #888;
    color: #fff;
  }

  .ranking-section .final-cta.is-muted .cta-btn {
    background: #3a2020;
    color: #fff;
  }

  .ranking-section .final-cta.is-muted .cta-btn:hover {
    background: #3a2020;
    color: #fff;
  }

  .ranking-section .final-cta.is-meta-only {
    padding-top: 20px;
    padding-bottom: 20px;
  }

  .ranking-section .final-cta.is-meta-only .final-cta__meta {
    margin-top: 0;
    font-size: calc(0.88rem * var(--wl-text-scale));
  }

  .author-bio {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    padding: 22px;
    margin-top: 28px;
  }

  .author-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--wl-accent), var(--wl-danger));
    color: #fff;
    flex-shrink: 0;
  }

  .author-avatar .material-icon {
    font-size: 28px;
  }

  .author-bio__title {
    margin: 0 0 4px;
    color: var(--wl-ink);
    font-size: calc(1.08rem * var(--wl-text-scale));
    font-weight: 700;
  }

  .author-bio__role {
    margin: 0 0 10px;
    color: var(--wl-accent);
    font-size: calc(0.88rem * var(--wl-text-scale));
    font-weight: 700;
    line-height: 1.5;
  }

  .author-bio__text {
    color: var(--wl-muted);
    font-size: calc(0.96rem * var(--wl-text-scale));
    line-height: 1.8;
  }

  .footer-note {
    margin-top: 18px;
    color: var(--wl-muted);
    font-size: calc(0.9rem * var(--wl-text-scale));
    line-height: 1.75;
    text-align: center;
  }

  @media screen and (max-width: 990px) {
    .method-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .how-steps,
    .guide-grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .wrist-listicle__hero {
      padding: 38px 18px 32px;
      border-radius: 22px;
    }

    .wrist-listicle__title-emphasis {
      font-size: clamp(0.92rem, 4vw, 1.22rem);
    }

    .wrist-listicle__section {
      margin-top: 38px;
    }

    .method-grid,
    .pros-cons {
      grid-template-columns: 1fr;
    }

    .product-card__body {
      padding: 20px 18px 0;
    }

    .product-card__header {
      padding: 22px 18px 0;
    }

    .final-cta,
    .why-section {
      padding: 28px 20px;
    }

    .ranking-section .final-cta .cta-btn {
      width: 100%;
      min-width: 0;
    }

    .author-bio {
      padding: 18px;
      flex-direction: column;
    }

    .score-row {
      grid-template-columns: minmax(100px, 120px) 1fr 40px;
    }

    .faq-q {
      font-size: calc(1rem * var(--wl-text-scale));
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{%- endstyle -%}

<article class="wrist-listicle section-{{ section.id }}-padding">
  <div class="page-width{{ page_narrow_class }}">
    <div class="wrist-listicle__stack">
      <header class="wrist-listicle__hero">
        <div class="wrist-listicle__hero-inner">
          {%- if section.settings.hero_badge != blank -%}
            <div class="wrist-listicle__eyebrow">{{ section.settings.hero_badge | escape }}</div>
          {%- endif -%}

          {%- assign hero_title = section.settings.hero_title -%}
          {%- if hero_title == blank -%}
            {%- assign hero_title = article.title -%}
          {%- endif -%}
          <h1 class="wrist-listicle__title">
            <span class="wrist-listicle__title-main">{{ hero_title | escape | newline_to_br }}</span>
            {%- if section.settings.hero_title_emphasis != blank -%}
              <br><em class="wrist-listicle__title-emphasis">{{ section.settings.hero_title_emphasis | escape }}</em>
            {%- endif -%}
          </h1>

          {%- if section.settings.hero_byline != blank -%}
            <p class="wrist-listicle__byline">{{ section.settings.hero_byline | escape }}</p>
          {%- endif -%}

          <div class="wrist-listicle__pills" aria-label="Highlights">
            {%- if section.settings.hero_pill_1 != blank -%}
              <span class="wrist-listicle__pill">
                {%- if section.settings.hero_pill_1_icon != blank -%}<span class="wrist-listicle__pill-icon" aria-hidden="true">{{ section.settings.hero_pill_1_icon | escape }}</span>{%- endif -%}
                <span>{{ section.settings.hero_pill_1 | escape }}</span>
              </span>
            {%- endif -%}
            {%- if section.settings.hero_pill_2 != blank -%}
              <span class="wrist-listicle__pill">
                {%- if section.settings.hero_pill_2_icon != blank -%}<span class="wrist-listicle__pill-icon" aria-hidden="true">{{ section.settings.hero_pill_2_icon | escape }}</span>{%- endif -%}
                <span>{{ section.settings.hero_pill_2 | escape }}</span>
              </span>
            {%- endif -%}
            {%- if section.settings.hero_pill_3 != blank -%}
              <span class="wrist-listicle__pill">
                {%- if section.settings.hero_pill_3_icon != blank -%}<span class="wrist-listicle__pill-icon" aria-hidden="true">{{ section.settings.hero_pill_3_icon | escape }}</span>{%- endif -%}
                <span>{{ section.settings.hero_pill_3 | escape }}</span>
              </span>
            {%- endif -%}
            {%- if section.settings.hero_pill_4 != blank -%}
              <span class="wrist-listicle__pill">
                {%- if section.settings.hero_pill_4_icon != blank -%}<span class="wrist-listicle__pill-icon" aria-hidden="true">{{ section.settings.hero_pill_4_icon | escape }}</span>{%- endif -%}
                <span>{{ section.settings.hero_pill_4 | escape }}</span>
              </span>
            {%- endif -%}
          </div>
        </div>
      </header>

      <section class="wrist-listicle__intro">
        {%- if section.settings.intro_content != blank -%}
          <div class="wrist-listicle__intro-copy rte">
            {{ section.settings.intro_content }}
          </div>
        {%- endif -%}

        {%- if section.settings.intro_pull_quote != blank -%}
          <div class="wrist-listicle__pullquote">
            <p>{{ section.settings.intro_pull_quote | escape }}</p>
          </div>
        {%- endif -%}
      </section>

      <section class="wrist-listicle__section">
        <div class="wrist-listicle__section-label">
          <span>{{ section.settings.methodology_eyebrow | escape }}</span>
        </div>
        <div class="wrist-listicle__section-inner">
          <h2 class="wrist-listicle__section-title">{{ section.settings.methodology_title | escape }}</h2>
          {%- if section.settings.methodology_description != blank -%}
            <div class="wrist-listicle__section-intro rte">
              {{ section.settings.methodology_description }}
            </div>
          {%- endif -%}

          <div class="method-grid">
            {%- for block in method_cards -%}
              <div class="method-card" {{ block.shopify_attributes }} style="animation-delay: {{ forloop.index0 | times: 0.06 }}s;">
                {%- if block.settings.icon != blank -%}
                  <div class="method-card__icon">
                    {% render 'material-icon', icon: block.settings.icon, filled: true %}
                  </div>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="method-card__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="method-card__text">{{ block.settings.description | escape | newline_to_br }}</p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </section>

      <section class="wrist-listicle__section ranking-section">
        <div class="wrist-listicle__section-label">
          <span>{{ section.settings.ranking_eyebrow | escape }}</span>
        </div>
        <div class="wrist-listicle__section-inner">
          {%- if section.settings.ranking_title != blank -%}
            <h2 class="wrist-listicle__section-title">{{ section.settings.ranking_title | escape }}</h2>
          {%- endif -%}

          {%- if section.settings.ranking_intro != blank -%}
            <div class="ranking-intro rte">
              {{ section.settings.ranking_intro }}
            </div>
          {%- endif -%}

          {%- for block in ranking_cards -%}
            <div class="product-card{% if block.settings.comparison_top_pick %} is-top-pick{% endif %}" {{ block.shopify_attributes }} style="animation-delay: {{ forloop.index0 | times: 0.08 }}s;">
              <div class="product-card__header">
                <div class="product-card__rankline">
                  {%- if block.settings.rank_text != blank -%}
                    <div class="product-card__rank tone-{{ block.settings.tone }}">{{ block.settings.rank_text | escape }}</div>
                  {%- endif -%}
                  <div class="product-card__label{% if block.settings.comparison_top_pick %} is-pick{% endif %}">
                    {{ block.settings.label | escape }}
                  </div>
                </div>
              </div>

              <div class="product-card__body">
                {%- if block.settings.title != blank -%}
                  <h3 class="product-card__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.tagline != blank -%}
                  <p class="product-card__tagline">{{ block.settings.tagline | escape }}</p>
                {%- endif -%}

                <div class="product-visual"{% if block.settings.visual_background != blank %} style="background: {{ block.settings.visual_background | escape }};"{% endif %}>
                  <div class="product-visual__inner">
                    {%- if block.settings.visual_emoji != blank -%}
                      <div class="product-visual__icon">{{ block.settings.visual_emoji | escape }}</div>
                    {%- elsif block.settings.icon != blank -%}
                      <div class="product-visual__icon">
                        {% render 'material-icon', icon: block.settings.icon, filled: true %}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.visual_title != blank -%}
                      <div class="product-visual__title">{{ block.settings.visual_title | escape }}</div>
                    {%- endif -%}
                    {%- if block.settings.visual_note != blank -%}
                      <div class="product-visual__note">{{ block.settings.visual_note | escape | newline_to_br }}</div>
                    {%- endif -%}
                  </div>
                  {%- if block.settings.grade != blank -%}
                    <div class="grade-badge tone-{{ block.settings.tone }}">{{ block.settings.grade | escape }}</div>
                  {%- endif -%}
                </div>

                {%- if block.settings.specs != blank -%}
                  {%- assign spec_lines = block.settings.specs | newline_to_br | split: '<br />' -%}
                  <table class="specs-table">
                    {%- for spec_line in spec_lines -%}
                      {%- assign spec_line = spec_line | strip -%}
                      {%- if spec_line != blank -%}
                        {%- assign spec_parts = spec_line | split: '|' -%}
                        <tr>
                          <td>{{ spec_parts[0] | strip | escape }}</td>
                          <td>{{ spec_parts[1] | default: '' | strip | escape }}</td>
                        </tr>
                      {%- endif -%}
                    {%- endfor -%}
                  </table>
                {%- endif -%}

                {%- assign callout_content = block.settings.callout | strip -%}
                {%- assign has_real_callout = false -%}
                {%- if callout_content != blank and callout_content != '<p>Enter a callout here.</p>' -%}
                  {%- assign has_real_callout = true -%}
                {%- endif -%}

                {%- if block.settings.summary != blank -%}
                  {%- assign show_summary_heading = false -%}
                  {%- if section.settings.summary_heading != blank and has_real_callout -%}
                    {%- assign show_summary_heading = true -%}
                  {%- endif -%}
                  <div class="rte">
                    {%- if show_summary_heading -%}
                      <h4 class="product-card__subheading">{{ section.settings.summary_heading | escape }}</h4>
                    {%- endif -%}
                    {{ block.settings.summary }}
                  </div>
                {%- endif -%}

                {%- if has_real_callout -%}
                  <div class="highlight-box rte">
                    {{ callout_content }}
                  </div>
                {%- endif -%}

                {%- if block.settings.how_steps != blank -%}
                  {%- assign step_lines = block.settings.how_steps | newline_to_br | split: '<br />' -%}
                  <h4 class="product-card__subheading">{{ section.settings.how_it_works_heading | escape }}</h4>
                  <div class="how-steps">
                    {%- for step_line in step_lines -%}
                      {%- assign step_line = step_line | strip -%}
                      {%- if step_line != blank -%}
                        {%- assign step_parts = step_line | split: '|' -%}
                        <div class="how-step">
                          <div class="step-num">{{ forloop.index }}</div>
                          {%- if step_parts[0] != blank -%}
                            <h5>{{ step_parts[0] | strip | escape }}</h5>
                          {%- endif -%}
                          {%- if step_parts[1] != blank -%}
                            <p>{{ step_parts[1] | strip | escape }}</p>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.testimonials != blank -%}
                  {%- assign testimonial_lines = block.settings.testimonials | newline_to_br | split: '<br />' -%}
                  <h4 class="product-card__subheading">{{ section.settings.testimonials_heading | escape }}</h4>
                  {%- for testimonial_line in testimonial_lines -%}
                    {%- assign testimonial_line = testimonial_line | strip -%}
                    {%- if testimonial_line != blank -%}
                      {%- assign testimonial_parts = testimonial_line | split: '|' -%}
                      <div class="testimonial-strip">
                        <div class="testimonial-stars">★★★★★</div>
                        <p>"{{ testimonial_parts[0] | strip | escape }}"</p>
                        {%- if testimonial_parts[1] != blank -%}
                          <div class="attr">— {{ testimonial_parts[1] | strip | escape }}</div>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}

                {%- if block.settings.metrics != blank -%}
                  {%- assign metric_lines = block.settings.metrics | newline_to_br | split: '<br />' -%}
                  <h4 class="product-card__subheading">{{ section.settings.scores_heading | escape }}</h4>
                  <div class="score-grid">
                    {%- for metric_line in metric_lines -%}
                      {%- assign metric_line = metric_line | strip -%}
                      {%- if metric_line != blank -%}
                        {%- assign metric_parts = metric_line | split: '|' -%}
                        {%- assign metric_percent_raw = metric_parts[1] | default: '' | strip -%}
                        {%- assign metric_score_raw = metric_parts[2] | default: '' | strip -%}
                        {%- assign metric_percent_clean = metric_percent_raw | remove: '%' | strip -%}
                        {%- assign metric_score_clean = metric_score_raw | remove: '/10' | remove: '%' | strip -%}
                        {%- assign metric_percent_num = metric_percent_clean | plus: 0 -%}
                        {%- assign metric_score_num = metric_score_clean | plus: 0 -%}
                        {%- assign metric_width_num = 0 -%}
                        {%- assign metric_value = metric_score_raw -%}
                        {%- if metric_percent_raw != blank and metric_score_raw != blank -%}
                          {%- assign metric_width_num = metric_percent_num -%}
                        {%- elsif metric_percent_raw != blank and metric_percent_num <= 10 -%}
                          {%- assign metric_width_num = metric_percent_num | times: 10 -%}
                          {%- assign metric_value = metric_percent_raw -%}
                        {%- elsif metric_percent_raw != blank -%}
                          {%- assign metric_width_num = metric_percent_num -%}
                          {%- assign metric_value = metric_percent_num | times: 0.1 -%}
                        {%- elsif metric_score_raw != blank -%}
                          {%- assign metric_width_num = metric_score_num | times: 10 -%}
                        {%- endif -%}
                        {%- if metric_width_num > 100 -%}
                          {%- assign metric_width_num = 100 -%}
                        {%- elsif metric_width_num < 0 -%}
                          {%- assign metric_width_num = 0 -%}
                        {%- endif -%}
                        {%- assign metric_width = metric_width_num | append: '%' -%}
                        {%- assign metric_bar_class = 'score-bar' -%}
                        {%- if metric_width_num < 80 -%}
                          {%- assign metric_bar_class = 'score-bar low' -%}
                        {%- elsif metric_width_num < 90 -%}
                          {%- assign metric_bar_class = 'score-bar mid' -%}
                        {%- endif -%}
                        <div class="score-row">
                          <span class="score-label">{{ metric_parts[0] | strip | escape }}</span>
                          <div class="score-bar-bg" style="background: linear-gradient(90deg, #7a9e8a 0%, #b5d4c3 {{ metric_width }}, #ede8e0 {{ metric_width }}, #ede8e0 100%);">
                            <div class="{{ metric_bar_class }}" style="width: {{ metric_width }};"></div>
                          </div>
                          <span class="score-val">{{ metric_value | escape }}</span>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.pros != blank or block.settings.cons != blank -%}
                  {%- assign pros_heading = block.settings.pros_heading_override | default: section.settings.pros_heading -%}
                  {%- assign cons_heading = block.settings.cons_heading_override | default: section.settings.cons_heading -%}
                  <div class="pros-cons"{% unless block.settings.pros != blank and block.settings.cons != blank %} style="grid-template-columns: 1fr;"{% endunless %}>
                    {%- if block.settings.pros != blank -%}
                      {%- assign pros_lines = block.settings.pros | newline_to_br | split: '<br />' -%}
                      <div class="pros">
                        <h4>{{ pros_heading | escape }}</h4>
                        <ul>
                          {%- for pros_line in pros_lines -%}
                            {%- assign pros_line = pros_line | strip -%}
                            {%- if pros_line != blank -%}
                              <li>{{ pros_line | escape }}</li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.cons != blank -%}
                      {%- assign cons_lines = block.settings.cons | newline_to_br | split: '<br />' -%}
                      <div class="cons">
                        <h4>{{ cons_heading | escape }}</h4>
                        <ul>
                          {%- for cons_line in cons_lines -%}
                            {%- assign cons_line = cons_line | strip -%}
                            {%- if cons_line != blank -%}
                              <li>{{ cons_line | escape }}</li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.bottom_line != blank -%}
                  <div class="verdict-box rte">
                    <h4>{{ section.settings.bottom_line_heading | escape }}</h4>
                    {{ block.settings.bottom_line }}
                  </div>
                {%- endif -%}
              </div>

              {%- assign show_ranking_cta = false -%}
              {%- if block.settings.cta_variant != 'hidden' and block.settings.cta_label != blank -%}
                {%- assign show_ranking_cta = true -%}
              {%- elsif block.settings.cta_variant != 'hidden' and block.settings.cta_meta != blank -%}
                {%- assign show_ranking_cta = true -%}
              {%- endif -%}
              {%- if show_ranking_cta -%}
                <div class="final-cta is-{{ block.settings.cta_variant }}{% if block.settings.cta_label == blank %} is-meta-only{% endif %}" style="background: {% if block.settings.cta_variant == 'primary' %}linear-gradient(135deg,#2d2926,#3d2d20){% elsif block.settings.cta_variant == 'secondary' %}linear-gradient(135deg,#2d2926,#3d2d20){% else %}linear-gradient(135deg,#3a2020,#4a2a2a){% endif %};">
                  {%- if block.settings.cta_label != blank -%}
                    {%- if block.settings.cta_link != blank -%}
                      <a href="{{ block.settings.cta_link }}" class="cta-btn">
                        {{ block.settings.cta_label | escape }}
                      </a>
                    {%- else -%}
                      <span class="cta-btn" role="link" aria-disabled="true">
                        {{ block.settings.cta_label | escape }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}
                  {%- if block.settings.cta_meta != blank -%}
                    <div class="final-cta__meta">{{ block.settings.cta_meta | escape }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </section>

      <section class="wrist-listicle__section">
        <div class="wrist-listicle__section-label">
          <span>{{ section.settings.comparison_eyebrow | escape }}</span>
        </div>
        <div class="wrist-listicle__section-inner">
          <h2 class="wrist-listicle__section-title">{{ section.settings.comparison_title | escape }}</h2>
          {%- if section.settings.comparison_intro != blank -%}
            <p class="wrist-listicle__section-intro">{{ section.settings.comparison_intro | escape }}</p>
          {%- endif -%}

          <div class="compare-table-wrap">
            <table class="compare-table">
              <thead>
                <tr>
                  <th>Device</th>
                  <th>Full Arm Engagement?</th>
                  <th>Progress Tracking</th>
                  <th>Desk-Friendly?</th>
                  <th>Wrist-Safe?</th>
                  <th>12-Week Consistency</th>
                  <th>Score</th>
                </tr>
              </thead>
              <tbody>
                {%- for block in ranking_cards -%}
                  <tr class="{% if block.settings.comparison_top_pick %}top-pick{% endif %}">
                    <td class="product-name-cell">{{ block.settings.title | escape }}</td>
                    <td>{{ block.settings.comparison_engagement | escape }}</td>
                    <td>{{ block.settings.comparison_tracking | escape }}</td>
                    <td>{{ block.settings.comparison_desk | escape }}</td>
                    <td>{{ block.settings.comparison_wrist | escape }}</td>
                    <td>{{ block.settings.comparison_consistency | escape }}</td>
                    <td>
                      <span class="score-chip tone-{{ block.settings.tone }}">
                        {{ block.settings.comparison_score | escape }}
                      </span>
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>

          {%- if section.settings.comparison_note != blank -%}
            <p class="footer-note" style="text-align: left; margin-top: 8px;">{{ section.settings.comparison_note | escape }}</p>
          {%- endif -%}
        </div>
      </section>

      <section class="why-section">
        <div class="wrist-listicle__section-inner">
          <div class="wrist-listicle__section-label">
            <span>{{ section.settings.why_eyebrow | escape }}</span>
          </div>
          <h2 class="wrist-listicle__section-title">{{ section.settings.why_title | escape }}</h2>
          {%- if section.settings.why_content != blank -%}
            <div class="rte">
              {{ section.settings.why_content }}
            </div>
          {%- endif -%}
        </div>
      </section>

      <section class="wrist-listicle__section">
        <div class="wrist-listicle__section-label">
          <span>{{ section.settings.guide_eyebrow | escape }}</span>
        </div>
        <div class="wrist-listicle__section-inner">
          <h2 class="wrist-listicle__section-title">{{ section.settings.guide_title | escape }}</h2>
          <div class="guide-grid">
            <div class="guide-card guide-card--good">
              <h3 class="guide-card__title">{{ section.settings.guide_good_title | escape }}</h3>
              {%- if section.settings.guide_good_content != blank -%}
                <div class="rte">{{ section.settings.guide_good_content }}</div>
              {%- endif -%}
            </div>
            <div class="guide-card guide-card--bad">
              <h3 class="guide-card__title">{{ section.settings.guide_bad_title | escape }}</h3>
              {%- if section.settings.guide_bad_content != blank -%}
                <div class="rte">{{ section.settings.guide_bad_content }}</div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </section>

      <section class="faq-section">
        <div class="wrist-listicle__section-label">
          <span>{{ section.settings.faq_eyebrow | escape }}</span>
        </div>
        <div class="wrist-listicle__section-inner">
          <h2 class="wrist-listicle__section-title">{{ section.settings.faq_title | escape }}</h2>
          {%- if section.settings.faq_intro != blank -%}
            <p class="wrist-listicle__section-intro">{{ section.settings.faq_intro | escape }}</p>
          {%- endif -%}

          {%- for block in faq_items -%}
            <div class="faq-item{% if forloop.first %} is-open{% endif %}" {{ block.shopify_attributes }}>
              <button type="button" class="faq-q">
                <span>{{ block.settings.question | escape }}</span>
              </button>
              {%- if block.settings.answer != blank -%}
                <div class="faq-a rte">
                  {{ block.settings.answer }}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </section>

      <section class="wrist-listicle__section final-verdict-section">
        <div class="wrist-listicle__section-inner">
          <div class="wrist-listicle__section-label" style="margin-bottom: 18px;">
            <span>{{ section.settings.verdict_eyebrow | escape }}</span>
          </div>
          <h2 class="wrist-listicle__section-title">{{ section.settings.verdict_title | escape }}</h2>
          {%- if section.settings.verdict_content != blank -%}
            <div class="final-verdict-copy rte">
              {{ section.settings.verdict_content }}
            </div>
          {%- endif -%}

          {%- if section.settings.final_cta_title != blank or section.settings.final_cta_text != blank -%}
            <div class="final-cta">
              {%- if section.settings.final_cta_title != blank -%}
                <h2>{{ section.settings.final_cta_title | escape }}</h2>
              {%- endif -%}
              {%- if section.settings.final_cta_text != blank -%}
                <p>{{ section.settings.final_cta_text | escape }}</p>
              {%- endif -%}
              {%- if section.settings.final_cta_link != blank and section.settings.final_cta_button != blank -%}
                <a href="{{ section.settings.final_cta_link }}" class="cta-btn">{{ section.settings.final_cta_button | escape }}</a>
              {%- elsif section.settings.final_cta_button != blank -%}
                <span class="cta-btn" role="link" aria-disabled="true">{{ section.settings.final_cta_button | escape }}</span>
              {%- endif -%}
              {%- if section.settings.final_cta_meta != blank -%}
                <div class="final-cta__meta">{{ section.settings.final_cta_meta | escape }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.author_title != blank or section.settings.author_bio != blank -%}
            <div class="author-bio">
              <div class="author-avatar">
                {% render 'material-icon', icon: section.settings.author_avatar_icon, filled: true %}
              </div>
              <div>
                {%- if section.settings.author_title != blank -%}
                  <h3 class="author-bio__title">{{ section.settings.author_title | escape }}</h3>
                {%- endif -%}
                {%- if section.settings.author_role != blank -%}
                  <p class="author-bio__role">{{ section.settings.author_role | escape }}</p>
                {%- endif -%}
                {%- if section.settings.author_bio != blank -%}
                  <div class="author-bio__text rte">{{ section.settings.author_bio }}</div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.footer_note != blank -%}
            <div class="footer-note rte">{{ section.settings.footer_note }}</div>
          {%- endif -%}
        </div>
      </section>
    </div>
  </div>
</article>

<script type="module">
  const sectionRoot = document.querySelector('.wrist-listicle');
  if (sectionRoot) {
    const faqItems = sectionRoot.querySelectorAll('.faq-item');

    faqItems.forEach((item) => {
      const button = item.querySelector('.faq-q');
      if (!button) return;

      button.addEventListener('click', () => {
        const wasOpen = item.classList.contains('is-open');
        faqItems.forEach((other) => other.classList.remove('is-open'));
        if (!wasOpen) item.classList.add('is-open');
      });
    });

  }
</script>

